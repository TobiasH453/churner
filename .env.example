# 1step_cashouts local environment template
# Copy this file to .env and replace placeholder values.

# Required: Anthropic API key (format: sk-ant-...)
ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key

# Required: Amazon personal account credentials
AMAZON_EMAIL=replace-with-personal-amazon-email
AMAZON_PASSWORD=replace-with-personal-amazon-password
# Optional: TOTP seed for auto-filled 2FA code
AMAZON_TOTP_SECRET=

# Required: Amazon business account credentials
AMAZON_BUSINESS_EMAIL=replace-with-business-amazon-email
AMAZON_BUSINESS_PASSWORD=replace-with-business-amazon-password
# Optional: TOTP seed for auto-filled 2FA code
AMAZON_BUSINESS_TOTP_SECRET=

# Required for ElectronicsBuyer submission path
EB_LOGIN_EMAIL=replace-with-electronicsbuyer-login-email

# Runtime behavior
BROWSER_HEADLESS=false
MAX_RETRIES=3

# Service ports (must stay unique on this machine)
SERVER_PORT=18080
N8N_PORT=15678

# Optional service identity overrides
AMAZON_AGENT_PM2_NAME=amazon-agent-local
N8N_PM2_NAME=n8n-server-local

# Optional path overrides
PM2_HOME=.pm2
N8N_USER_FOLDER=.n8n
PYTHON_BIN=venv/bin/python
N8N_BIN=n8n

# Timezone defaults
TZ=America/Los_Angeles
